# Local development: copy to .env.local
# Amplify Hosting: App settings → Environment variables → add for "All branches"
# then Redeploy. Values must be available at RUNTIME (Hosting compute), not build-only.

RESEND_API_KEY=re_xxxxxxxx
BOOKING_TO_EMAIL=prachi.sharma@orion-led.com

# Prefer quotes in Amplify console if using display name.
# If angle brackets get stripped by Amplify, either use bare email:
#   BOOKING_FROM_EMAIL=onboarding@resend.dev
# or verify your domain and use:
#   BOOKING_FROM_EMAIL=Orion Experience Centre <bookings@orion-led.com>
BOOKING_FROM_EMAIL=Orion Experience Centre <onboarding@resend.dev>
